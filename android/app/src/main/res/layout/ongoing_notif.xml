<?xml version="1.0" encoding="utf-8"?>
<!-- Sürekli "sıradaki vakit" bildiriminin DARALTILMIŞ görünümü: üstte uygulama
     adı (SELAYA), altında tek satır canlı geri sayım. Chronometer'i sistem
     saniyede bir kendiliğinden tikler (jank yok, ekran kapalıyken de çalışır) →
     "🕌 İmsak vaktine kalan : 5:10:05". -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:id="@+id/appname"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SELAYA"
        android:textAppearance="@style/TextAppearance.Compat.Notification.Title"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end" />

    <Chronometer
        android:id="@+id/chrono"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.Compat.Notification.Title"
        android:maxLines="1"
        android:ellipsize="end" />
</LinearLayout>
