<?xml version="1.0" encoding="utf-8"?>
<!-- Semi-transparent (~70%) dark glass so the wallpaper shows through while the
     gold/white widget text stays legible over any background. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:startColor="#990E1322"
        android:endColor="#9905070D"
        android:angle="135" />
    <corners android:radius="10dp" />
    <stroke android:width="1dp" android:color="#4DE0B250" />
</shape>
