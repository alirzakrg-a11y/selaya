[
  {
    "ayah": 1,
    "arabic": "أَلْهَىٰكُمُ ٱلتَّكَاثُرُ",
    "transliteration": "Elhakumut tekasur",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/102001.mp3",
    "translations": {
      "tr": "Çoğunluk olmak iddianız sizi o kadar meşgul etti ki, mezarları ziyaretle oradakileri de sayacak kadar oldunuz.",
      "en": "Competition in [worldly] increase diverts you"
    }
  },
  {
    "ayah": 2,
    "arabic": "حَتَّىٰ زُرْتُمُ ٱلْمَقَابِرَ",
    "transliteration": "Hatta zurtumul mekabir",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/102002.mp3",
    "translations": {
      "tr": "Çoğunluk olmak iddianız sizi o kadar meşgul etti ki, mezarları ziyaretle oradakileri de sayacak kadar oldunuz.",
      "en": "Until you visit the graveyards."
    }
  },
  {
    "ayah": 3,
    "arabic": "كَلَّا سَوْفَ تَعْلَمُونَ",
    "transliteration": "Kella sevfe ta'lemun",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/102003.mp3",
    "translations": {
      "tr": "Hayır; öyle olmayın; yakında bileceksiniz.",
      "en": "No! You are going to know."
    }
  },
  {
    "ayah": 4,
    "arabic": "ثُمَّ كَلَّا سَوْفَ تَعْلَمُونَ",
    "transliteration": "Summe kella sevfe ta'lemun",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/102004.mp3",
    "translations": {
      "tr": "Hayır; gözünüzü açın; yakında bileceksiniz.",
      "en": "Then no! You are going to know."
    }
  },
  {
    "ayah": 5,
    "arabic": "كَلَّا لَوْ تَعْلَمُونَ عِلْمَ ٱلْيَقِينِ",
    "transliteration": "Kella lev ta'lemune ilmel yakin",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/102005.mp3",
    "translations": {
      "tr": "Dikkat edin, şayet yaptığınızın sonucunu kesin olarak bir bilseniz!",
      "en": "No! If you only knew with knowledge of certainty..."
    }
  },
  {
    "ayah": 6,
    "arabic": "لَتَرَوُنَّ ٱلْجَحِيمَ",
    "transliteration": "Le terevunnel cahim",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/102006.mp3",
    "translations": {
      "tr": "And olsun ki, cehennemi göreceksiniz.",
      "en": "You will surely see the Hellfire."
    }
  },
  {
    "ayah": 7,
    "arabic": "ثُمَّ لَتَرَوُنَّهَا عَيْنَ ٱلْيَقِينِ",
    "transliteration": "Summe le terevunneha aynel yakin",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/102007.mp3",
    "translations": {
      "tr": "And olsun ki, onu gözünüzle kesin olarak göreceksiniz.",
      "en": "Then you will surely see it with the eye of certainty."
    }
  },
  {
    "ayah": 8,
    "arabic": "ثُمَّ لَتُسْـَٔلُنَّ يَوْمَئِذٍ عَنِ ٱلنَّعِيمِ",
    "transliteration": "Summe le tus'elunne yevmeizin anin naim",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/102008.mp3",
    "translations": {
      "tr": "Sonra o gün, size verilmiş olan her nimetten sorguya çekileceksiniz.",
      "en": "Then you will surely be asked that Day about pleasure."
    }
  }
]
