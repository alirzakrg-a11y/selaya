[
  {
    "ayah": 1,
    "arabic": "قُلْ أَعُوذُ بِرَبِّ الْفَلَقِ",
    "transliteration": "Kul euzu bi rabbil felak",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/113001.mp3",
    "translations": {
      "tr": "De ki: Sabahın Rabbine sığınırım,",
      "en": "Say, I seek refuge in the Lord of daybreak,"
    }
  },
  {
    "ayah": 2,
    "arabic": "مِن شَرِّ مَا خَلَقَ",
    "transliteration": "Min şerri ma halak",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/113002.mp3",
    "translations": {
      "tr": "yarattığı şeylerin şerrinden,",
      "en": "from the evil of that which He created,"
    }
  },
  {
    "ayah": 3,
    "arabic": "وَمِن شَرِّ غَاسِقٍ إِذَا وَقَبَ",
    "transliteration": "Ve min şerri gasikın iza vekab",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/113003.mp3",
    "translations": {
      "tr": "karanlığı çöktüğünde gecenin şerrinden,",
      "en": "and from the evil of darkness when it settles,"
    }
  },
  {
    "ayah": 4,
    "arabic": "وَمِن شَرِّ النَّفَّاثَاتِ فِي الْعُقَدِ",
    "transliteration": "Ve min şerrin neffasati fil ukad",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/113004.mp3",
    "translations": {
      "tr": "düğümlere üfleyenlerin şerrinden,",
      "en": "and from the evil of the blowers in knots,"
    }
  },
  {
    "ayah": 5,
    "arabic": "وَمِن شَرِّ حَاسِدٍ إِذَا حَسَدَ",
    "transliteration": "Ve min şerri hasidin iza hased",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/113005.mp3",
    "translations": {
      "tr": "ve haset ettiğinde hasetçinin şerrinden.",
      "en": "and from the evil of an envier when he envies."
    }
  }
]
