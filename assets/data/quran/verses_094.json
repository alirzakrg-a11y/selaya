[
  {
    "ayah": 1,
    "arabic": "أَلَمْ نَشْرَحْ لَكَ صَدْرَكَ",
    "transliteration": "E lem neşrah leke sadrek",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/094001.mp3",
    "translations": {
      "tr": "Senin gönlünü açmadık mı?",
      "en": "Did We not expand for you, [O Muhammad], your breast?"
    }
  },
  {
    "ayah": 2,
    "arabic": "وَوَضَعْنَا عَنكَ وِزْرَكَ",
    "transliteration": "Ve vedagna anke vizrek",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/094002.mp3",
    "translations": {
      "tr": "Belini büken yükünü üzerinden almadık mı?",
      "en": "And We removed from you your burden"
    }
  },
  {
    "ayah": 3,
    "arabic": "ٱلَّذِىٓ أَنقَضَ ظَهْرَكَ",
    "transliteration": "Ellezi enkada zahrek",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/094003.mp3",
    "translations": {
      "tr": "Belini büken yükünü üzerinden almadık mı?",
      "en": "Which had weighed upon your back"
    }
  },
  {
    "ayah": 4,
    "arabic": "وَرَفَعْنَا لَكَ ذِكْرَكَ",
    "transliteration": "Ve refa'na leke zikrek",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/094004.mp3",
    "translations": {
      "tr": "Senin şanını yükseltmedik mi?",
      "en": "And raised high for you your repute."
    }
  },
  {
    "ayah": 5,
    "arabic": "فَإِنَّ مَعَ ٱلْعُسْرِ يُسْرًا",
    "transliteration": "Fe inne maal usri yusra",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/094005.mp3",
    "translations": {
      "tr": "Elbette güçlükle beraber şüphesiz bir kolaylık vardır.",
      "en": "For indeed, with hardship [will be] ease."
    }
  },
  {
    "ayah": 6,
    "arabic": "إِنَّ مَعَ ٱلْعُسْرِ يُسْرًۭا",
    "transliteration": "İnne maal usri yusra",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/094006.mp3",
    "translations": {
      "tr": "Gerçekten, güçlükle beraber bir kolaylık vardır.",
      "en": "Indeed, with hardship [will be] ease."
    }
  },
  {
    "ayah": 7,
    "arabic": "فَإِذَا فَرَغْتَ فَٱنصَبْ",
    "transliteration": "Fe iza feragte fensab",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/094007.mp3",
    "translations": {
      "tr": "Öyleyse, bir işi bitirince diğerine giriş;",
      "en": "So when you have finished [your duties], then stand up [for worship]."
    }
  },
  {
    "ayah": 8,
    "arabic": "وَإِلَىٰ رَبِّكَ فَٱرْغَب",
    "transliteration": "Ve ila rabbike fergab",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/094008.mp3",
    "translations": {
      "tr": "Ve ümit edeceğini yalnız Rabbinden iste.",
      "en": "And to your Lord direct [your] longing."
    }
  }
]
