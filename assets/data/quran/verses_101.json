[
  {
    "ayah": 1,
    "arabic": "ٱلْقَارِعَةُ",
    "transliteration": "El kariah",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/101001.mp3",
    "translations": {
      "tr": "Gürültü koparacak olan",
      "en": "The Striking Calamity -"
    }
  },
  {
    "ayah": 2,
    "arabic": "مَا ٱلْقَارِعَةُ",
    "transliteration": "Mel kariah",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/101002.mp3",
    "translations": {
      "tr": "Nedir o gürültü koparacak olan?",
      "en": "What is the Striking Calamity?"
    }
  },
  {
    "ayah": 3,
    "arabic": "وَمَآ أَدْرَىٰكَ مَا ٱلْقَارِعَةُ",
    "transliteration": "Ve ma edrake mel kariah",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/101003.mp3",
    "translations": {
      "tr": "O gürültü koparacak olanın ne olduğunu sen bilir misin?",
      "en": "And what can make you know what is the Striking Calamity?"
    }
  },
  {
    "ayah": 4,
    "arabic": "يَوْمَ يَكُونُ ٱلنَّاسُ كَٱلْفَرَاشِ ٱلْمَبْثُوثِ",
    "transliteration": "Yevme yekunun nasu kel feraşil mebsus",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/101004.mp3",
    "translations": {
      "tr": "O gün insanlar, ateş etrafında çırpınıp dökülen pervaneye dönecekler.",
      "en": "It is the Day when people will be like moths, dispersed,"
    }
  },
  {
    "ayah": 5,
    "arabic": "وَتَكُونُ ٱلْجِبَالُ كَٱلْعِهْنِ ٱلْمَنفُوشِ",
    "transliteration": "Ve tekunul cibalu kel ıhnil menfuş",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/101005.mp3",
    "translations": {
      "tr": "Dağlar, atılmış renkli yüne benzeyecekler.",
      "en": "And the mountains will be like wool, fluffed up."
    }
  },
  {
    "ayah": 6,
    "arabic": "فَأَمَّا مَن ثَقُلَتْ مَوَٰزِينُهُۥ",
    "transliteration": "Fe emma men sekulet mevazinuh",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/101006.mp3",
    "translations": {
      "tr": "Ama tartıları ağır gelen kimse hoş bir hayat içinde olacaktır.",
      "en": "Then as for one whose scales are heavy [with good deeds],"
    }
  },
  {
    "ayah": 7,
    "arabic": "فَهُوَ فِى عِيشَةٍۢ رَّاضِيَةٍۢ",
    "transliteration": "Fe huve fi işetin radiyeh",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/101007.mp3",
    "translations": {
      "tr": "Ama tartıları ağır gelen kimse hoş bir hayat içinde olacaktır.",
      "en": "He will be in a pleasant life."
    }
  },
  {
    "ayah": 8,
    "arabic": "وَأَمَّا مَنْ خَفَّتْ مَوَٰزِينُهُۥ",
    "transliteration": "Ve emma men haffet mevazinuh",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/101008.mp3",
    "translations": {
      "tr": "Tartıları hafif gelenler ise,",
      "en": "But as for one whose scales are light,"
    }
  },
  {
    "ayah": 9,
    "arabic": "فَأُمُّهُۥ هَاوِيَةٌۭ",
    "transliteration": "Fe ummuhu haviyeh",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/101009.mp3",
    "translations": {
      "tr": "Onların yeri bir çukurdur.",
      "en": "His refuge will be an abyss."
    }
  },
  {
    "ayah": 10,
    "arabic": "وَمَآ أَدْرَىٰكَ مَا هِيَهْ",
    "transliteration": "Ve ma edrake mahiyeh",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/101010.mp3",
    "translations": {
      "tr": "O çukurun ne olduğunu sen bilir misin?",
      "en": "And what can make you know what that is?"
    }
  },
  {
    "ayah": 11,
    "arabic": "نَارٌ حَامِيَةٌۢ",
    "transliteration": "Narun hamiyeh",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/101011.mp3",
    "translations": {
      "tr": "O, kızgın bir ateştir.",
      "en": "It is a Fire, intensely hot."
    }
  }
]
