[
  {
    "ayah": 1,
    "arabic": "قُلْ هُوَ ٱللَّهُ أَحَدٌ",
    "transliteration": "Kul huvallahu ehad",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/112001.mp3",
    "translations": {
      "tr": "De ki: O Allah bir tektir.",
      "en": "Say, \"He is Allah, [who is] One,"
    }
  },
  {
    "ayah": 2,
    "arabic": "ٱللَّهُ ٱلصَّمَدُ",
    "transliteration": "Allahus samed",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/112002.mp3",
    "translations": {
      "tr": "Allah her şeyden müstağni ve her şey O'na muhtaçtır.",
      "en": "Allah, the Eternal Refuge."
    }
  },
  {
    "ayah": 3,
    "arabic": "لَمْ يَلِدْ وَلَمْ يُولَدْ",
    "transliteration": "Lem yelid ve lem yuled",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/112003.mp3",
    "translations": {
      "tr": "O doğurmamış ve doğmamıştır.",
      "en": "He neither begets nor is born,"
    }
  },
  {
    "ayah": 4,
    "arabic": "وَلَمْ يَكُن لَّهُۥ كُفُوًا أَحَدٌۢ",
    "transliteration": "Ve lem yekun lehu kufuven ehad",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/112004.mp3",
    "translations": {
      "tr": "Hiçbir şey O'na denk değildir.",
      "en": "Nor is there to Him any equivalent.\""
    }
  }
]
