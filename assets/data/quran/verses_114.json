[
  {
    "ayah": 1,
    "arabic": "قُلْ أَعُوذُ بِرَبِّ النَّاسِ",
    "transliteration": "Kul euzu bi rabbin nas",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/114001.mp3",
    "translations": {
      "tr": "De ki: İnsanların Rabbine sığınırım,",
      "en": "Say, I seek refuge in the Lord of mankind,"
    }
  },
  {
    "ayah": 2,
    "arabic": "مَلِكِ النَّاسِ",
    "transliteration": "Melikin nas",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/114002.mp3",
    "translations": {
      "tr": "insanların mutlak sahibine,",
      "en": "the Sovereign of mankind,"
    }
  },
  {
    "ayah": 3,
    "arabic": "إِلَٰهِ النَّاسِ",
    "transliteration": "İlahin nas",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/114003.mp3",
    "translations": {
      "tr": "insanların İlahına,",
      "en": "the God of mankind,"
    }
  },
  {
    "ayah": 4,
    "arabic": "مِن شَرِّ الْوَسْوَاسِ الْخَنَّاسِ",
    "transliteration": "Min şerril vesvasil hannas",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/114004.mp3",
    "translations": {
      "tr": "o sinsi vesvesecinin şerrinden,",
      "en": "from the evil of the retreating whisperer,"
    }
  },
  {
    "ayah": 5,
    "arabic": "الَّذِي يُوَسْوِسُ فِي صُدُورِ النَّاسِ",
    "transliteration": "Ellezi yuvesvisu fi sudurin nas",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/114005.mp3",
    "translations": {
      "tr": "o ki insanların göğüslerine vesvese verir,",
      "en": "who whispers in the breasts of mankind,"
    }
  },
  {
    "ayah": 6,
    "arabic": "مِنَ الْجِنَّةِ وَالنَّاسِ",
    "transliteration": "Minel cinneti ven nas",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/114006.mp3",
    "translations": {
      "tr": "gerek cinlerden, gerek insanlardan.",
      "en": "from among jinn and mankind."
    }
  }
]
