[
  {
    "ayah": 1,
    "arabic": "سَبِّحِ ٱسْمَ رَبِّكَ ٱلْأَعْلَى",
    "transliteration": "Sebbihısme rabbikel a'la",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/087001.mp3",
    "translations": {
      "tr": "Yüce Rabbinin adını tesbih et.",
      "en": "Exalt the name of your Lord, the Most High,"
    }
  },
  {
    "ayah": 2,
    "arabic": "ٱلَّذِى خَلَقَ فَسَوَّىٰ",
    "transliteration": "Ellezi halaka fesevva",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/087002.mp3",
    "translations": {
      "tr": "O, yaratıp şekil vermiştir.",
      "en": "Who created and proportioned"
    }
  },
  {
    "ayah": 3,
    "arabic": "وَٱلَّذِى قَدَّرَ فَهَدَىٰ",
    "transliteration": "Vellezi kaddere fe heda",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/087003.mp3",
    "translations": {
      "tr": "O, her şeyi ölçüyle yapıp doğru yolu göstermiştir.",
      "en": "And who destined and [then] guided"
    }
  },
  {
    "ayah": 4,
    "arabic": "وَٱلَّذِىٓ أَخْرَجَ ٱلْمَرْعَىٰ",
    "transliteration": "Vellezi ahrecel mer'a",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/087004.mp3",
    "translations": {
      "tr": "O, yeşillikler bitirmiştir.",
      "en": "And who brings out the pasture"
    }
  },
  {
    "ayah": 5,
    "arabic": "فَجَعَلَهُۥ غُثَآءً أَحْوَىٰ",
    "transliteration": "Fe cealehu gusaen ahva",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/087005.mp3",
    "translations": {
      "tr": "Sonra da onları siyah çerçöpe çevirmiştir.",
      "en": "And [then] makes it black stubble."
    }
  },
  {
    "ayah": 6,
    "arabic": "سَنُقْرِئُكَ فَلَا تَنسَىٰٓ",
    "transliteration": "Senukriuke fe la tensa",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/087006.mp3",
    "translations": {
      "tr": "Sana Kuran'ı Biz okutacağız ve asla unutmayacaksın;",
      "en": "We will make you recite, [O Muhammad], and you will not forget,"
    }
  },
  {
    "ayah": 7,
    "arabic": "إِلَّا مَا شَآءَ ٱللَّهُ ۚ إِنَّهُۥ يَعْلَمُ ٱلْجَهْرَ وَمَا يَخْفَىٰ",
    "transliteration": "İlla ma şaallah, innehu ya'lemul cehre ve ma yahfa",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/087007.mp3",
    "translations": {
      "tr": "Allah'ın dilediği bundan müstesnadır. Doğrusu açığı da, gizliyi de bilen O'dur.",
      "en": "Except what Allah should will. Indeed, He knows what is declared and what is hidden."
    }
  },
  {
    "ayah": 8,
    "arabic": "وَنُيَسِّرُكَ لِلْيُسْرَىٰ",
    "transliteration": "Ve nuyessiruke lil yusra",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/087008.mp3",
    "translations": {
      "tr": "Kolay olanı yapmayı sana kolaylaştırırız.",
      "en": "And We will ease you toward ease."
    }
  },
  {
    "ayah": 9,
    "arabic": "فَذَكِّرْ إِن نَّفَعَتِ ٱلذِّكْرَىٰ",
    "transliteration": "Fe zekkir in nefeatiz zikra",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/087009.mp3",
    "translations": {
      "tr": "Faydalı olacaksa insanlara öğüt ver.",
      "en": "So remind, if the reminder should benefit;"
    }
  },
  {
    "ayah": 10,
    "arabic": "سَيَذَّكَّرُ مَن يَخْشَىٰ",
    "transliteration": "Seyezzekkeru men yahşa",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/087010.mp3",
    "translations": {
      "tr": "Allah'tan korkan öğüt alacaktır.",
      "en": "He who fears [Allah] will be reminded."
    }
  },
  {
    "ayah": 11,
    "arabic": "وَيَتَجَنَّبُهَا ٱلْأَشْقَى",
    "transliteration": "Ve yetecennebuhel eşka",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/087011.mp3",
    "translations": {
      "tr": "Bedbaht olan ondan kaçınacaktır.",
      "en": "But the wretched one will avoid it -"
    }
  },
  {
    "ayah": 12,
    "arabic": "ٱلَّذِى يَصْلَى ٱلنَّارَ ٱلْكُبْرَىٰ",
    "transliteration": "Ellezi yaslen narel kubra",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/087012.mp3",
    "translations": {
      "tr": "O, en büyük ateşe yaslanacaktır.",
      "en": "[He] who will [enter and] burn in the greatest Fire,"
    }
  },
  {
    "ayah": 13,
    "arabic": "ثُمَّ لَا يَمُوتُ فِيهَا وَلَا يَحْيَىٰ",
    "transliteration": "Summe la yemutu fiha ve la yahya",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/087013.mp3",
    "translations": {
      "tr": "O, orada ne ölecektir ne de dirilecektir.",
      "en": "Neither dying therein nor living."
    }
  },
  {
    "ayah": 14,
    "arabic": "قَدْ أَفْلَحَ مَن تَزَكَّىٰ",
    "transliteration": "Kad efleha men tezekka",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/087014.mp3",
    "translations": {
      "tr": "Arınmış olan, Rabbinin adını anıp namaz kılan, saadete erişecektir.",
      "en": "He has certainly succeeded who purifies himself"
    }
  },
  {
    "ayah": 15,
    "arabic": "وَذَكَرَ ٱسْمَ رَبِّهِۦ فَصَلَّىٰ",
    "transliteration": "Ve zekeresme rabbihi fe salla",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/087015.mp3",
    "translations": {
      "tr": "Arınmış olan, Rabbinin adını anıp namaz kılan, saadete erişecektir.",
      "en": "And mentions the name of his Lord and prays."
    }
  },
  {
    "ayah": 16,
    "arabic": "بَلْ تُؤْثِرُونَ ٱلْحَيَوٰةَ ٱلدُّنْيَا",
    "transliteration": "Bel tu'sırunel hayated dunya",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/087016.mp3",
    "translations": {
      "tr": "Ama sizler dünya hayatını tercih ediyorsunuz.",
      "en": "But you prefer the worldly life,"
    }
  },
  {
    "ayah": 17,
    "arabic": "وَٱلْءَاخِرَةُ خَيْرٌۭ وَأَبْقَىٰٓ",
    "transliteration": "Vel ahıretu hayrun ve ebka",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/087017.mp3",
    "translations": {
      "tr": "Oysa ahiret daha iyi ve daha bakidir.",
      "en": "While the Hereafter is better and more enduring."
    }
  },
  {
    "ayah": 18,
    "arabic": "إِنَّ هَٰذَا لَفِى ٱلصُّحُفِ ٱلْأُولَىٰ",
    "transliteration": "İnne haza le fis suhufil ula",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/087018.mp3",
    "translations": {
      "tr": "Doğrusu bu hükümler ilk sahifelerde, İbrahim ve Musa'nın sahifelerinde de vardır.",
      "en": "Indeed, this is in the former scriptures,"
    }
  },
  {
    "ayah": 19,
    "arabic": "صُحُفِ إِبْرَٰهِيمَ وَمُوسَىٰ",
    "transliteration": "Suhufi ibrahime ve musa",
    "audio": "https://everyayah.com/data/Alafasy_128kbps/087019.mp3",
    "translations": {
      "tr": "Doğrusu bu hükümler ilk sahifelerde, İbrahim ve Musa'nın sahifelerinde de vardır.",
      "en": "The scriptures of Abraham and Moses."
    }
  }
]
