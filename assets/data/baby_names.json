[
  {"n": "Muhammed", "g": "m", "m": "Çokça övülen, hamdedilen. Peygamberimizin (s.a.v.) adı."},
  {"n": "Ahmet", "g": "m", "m": "En çok övülen, övgüye değer."},
  {"n": "Mahmut", "g": "m", "m": "Övülmüş, övgüye lâyık."},
  {"n": "Mustafa", "g": "m", "m": "Seçilmiş, seçkin. Peygamberimizin sıfatlarından."},
  {"n": "Ali", "g": "m", "m": "Yüce, ulu, yüksek."},
  {"n": "Ömer", "g": "m", "m": "Uzun ömürlü, hayat dolu."},
  {"n": "Osman", "g": "m", "m": "Toy kuş yavrusu; sahabe adı."},
  {"n": "Yusuf", "g": "m", "m": "Hz. Yûsuf'un adı; güzelliğiyle bilinir."},
  {"n": "İbrahim", "g": "m", "m": "Halkın babası; Hz. İbrâhim'in adı."},
  {"n": "İsmail", "g": "m", "m": "Allah işitir; Hz. İsmâil'in adı."},
  {"n": "Yakup", "g": "m", "m": "Hz. Yâkub'un adı."},
  {"n": "Süleyman", "g": "m", "m": "Huzurlu, esenlikli; Hz. Süleymân'ın adı."},
  {"n": "Davut", "g": "m", "m": "Sevgili, sevilen; Hz. Dâvud'un adı."},
  {"n": "Yunus", "g": "m", "m": "Hz. Yûnus'un adı; ünsiyet, dostluk."},
  {"n": "Yahya", "g": "m", "m": "Yaşayan, diri; Hz. Yahyâ'nın adı."},
  {"n": "Hamza", "g": "m", "m": "Aslan, heybetli; Hz. Hamza'nın adı."},
  {"n": "Bilal", "g": "m", "m": "Su, ıslaklık; ilk müezzin Bilâl-i Habeşî."},
  {"n": "Enes", "g": "m", "m": "Cana yakın, dost; sahabe Enes b. Mâlik."},
  {"n": "Talha", "g": "m", "m": "Bir ağaç adı; cennetle müjdelenen sahabe."},
  {"n": "Selman", "g": "m", "m": "Selâmette olan; Selmân-ı Fârisî."},
  {"n": "Furkan", "g": "m", "m": "Hak ile bâtılı ayıran; Kur'ân-ı Kerîm."},
  {"n": "Emir", "g": "m", "m": "Bey, komutan, yönetici."},
  {"n": "Eymen", "g": "m", "m": "Uğurlu, bereketli, sağ taraf."},
  {"n": "Kerem", "g": "m", "m": "Cömertlik, asalet, iyilik."},
  {"n": "Halit", "g": "m", "m": "Ebedî, kalıcı; Hâlid b. Velîd."},
  {"n": "Abdullah", "g": "m", "m": "Allah'ın kulu."},
  {"n": "Abdurrahman", "g": "m", "m": "Rahmân olan Allah'ın kulu."},
  {"n": "Salih", "g": "m", "m": "İyi, dürüst, yararlı işler yapan; Hz. Sâlih."},
  {"n": "Said", "g": "m", "m": "Mutlu, kutlu, bahtiyar."},
  {"n": "Ramazan", "g": "m", "m": "Oruç ayı; günahları yakıp temizleyen."},
  {"n": "Taha", "g": "m", "m": "Tâhâ sûresi; Peygamberimizin adlarından sayılır."},
  {"n": "Yasin", "g": "m", "m": "Yâsîn sûresi; Kur'ân'ın kalbi."},
  {"n": "Mü'min", "g": "m", "m": "İnanan, iman eden; Allah'ın isimlerinden."},
  {"n": "Kuddus", "g": "m", "m": "Her türlü eksiklikten uzak, tertemiz."},
  {"n": "Ayşe", "g": "f", "m": "Yaşayan, neşeli, dirik. Hz. Âişe vâlidemiz."},
  {"n": "Fatma", "g": "f", "m": "Sütten kesilen; Hz. Fâtıma vâlidemiz."},
  {"n": "Hatice", "g": "f", "m": "Erken doğan; Hz. Hatice vâlidemiz."},
  {"n": "Zeynep", "g": "f", "m": "Değerli, güzel kokulu süs ağacı; Hz. Zeyneb."},
  {"n": "Meryem", "g": "f", "m": "İbadet eden; Hz. Meryem."},
  {"n": "Esma", "g": "f", "m": "İsimler; Esmâ bint Ebû Bekir."},
  {"n": "Rabia", "g": "f", "m": "Dördüncü; bahar. Râbia el-Adeviyye."},
  {"n": "Sümeyye", "g": "f", "m": "İslam'ın ilk kadın şehidi."},
  {"n": "Elif", "g": "f", "m": "Ünsiyet, dostluk; elif harfi, dosdoğru."},
  {"n": "Büşra", "g": "f", "m": "Müjde, sevindirici haber."},
  {"n": "Kübra", "g": "f", "m": "En büyük, ulu."},
  {"n": "Zehra", "g": "f", "m": "Parlak, ışıl ışıl; Hz. Fâtıma'nın lakabı."},
  {"n": "Sare", "g": "f", "m": "Saf, hâlis; Hz. İbrâhim'in eşi."},
  {"n": "Asiye", "g": "f", "m": "Üzüntüyü gideren; Firavun'un mümin eşi."},
  {"n": "Safiye", "g": "f", "m": "Saf, hâlis, samimi dost; Hz. Safiyye."},
  {"n": "Rukiye", "g": "f", "m": "Yükselen, yüce; Peygamberimizin kızı."},
  {"n": "Halime", "g": "f", "m": "Yumuşak huylu; Peygamberimizin sütannesi."},
  {"n": "Beyza", "g": "f", "m": "Bembeyaz, tertemiz, lekesiz."},
  {"n": "Feyza", "g": "f", "m": "Bolluk, bereket, feyiz."},
  {"n": "Kevser", "g": "f", "m": "Cennette bir nehir; pek çok hayır. Kevser sûresi."},
  {"n": "Tuba", "g": "f", "m": "Cennette bir ağaç; 'ne mutlu' müjdesi."},
  {"n": "Sena", "g": "f", "m": "Övgü, methetme, yüceltme."},
  {"n": "Nur", "g": "f", "m": "Işık, aydınlık, parıltı. Nûr sûresi."},
  {"n": "Berra", "g": "f", "m": "İyi, hayırlı, itaatkâr."},
  {"n": "Hira", "g": "f", "m": "İlk vahyin geldiği Hira mağarası/dağı."},
  {"n": "Cennet", "g": "f", "m": "Bahçe; ahirette müminlerin mükâfat yurdu."},
  {"n": "Rana", "g": "f", "m": "Güzel, göz alıcı, hoş görünen."}
]
